# GHL credentials (Private Integration Token, READ-ONLY scope is sufficient)
GHL_PIT=pit-replace-me
GHL_LOCATION_ID=8aQHgJUX2bFYBHZ4Qizg

# Database (SQLite locally; Render injects Postgres URL automatically in prod)
DATABASE_URL=sqlite:///./shadow.db

# Service config
MODE=shadow
LOG_LEVEL=INFO

# Webhook shared secret (require X-Webhook-Secret header equal to this; leave empty to disable)
WEBHOOK_SECRET=

# --- Write controls (all default to safe/off; see config.py) ---
# Master switch — must be true for ANY write to GHL.
WRITES_ENABLED=false
# Pipelines fully migrated to code (writes allowed for every opp in them). Default: Production.
WRITE_ALLOWED_PIPELINE_IDS=88V9uYY6visCrtI9V0NR
# Scoped TEST opps that may receive writes even in a non-migrated pipeline (Sales sandbox).
WRITE_ALLOWED_OPP_IDS=
# Per-handler cutover knob: comma-separated HANDLER_IDs that may write to ANY opp they act on.
# Use this to take Sales movers live ONE stage at a time, e.g.:
#   WRITE_LIVE_HANDLERS=move-sales-s10-s20-inspection-complete
WRITE_LIVE_HANDLERS=
